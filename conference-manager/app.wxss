/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1AAD19;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.btn-primary {
  background: #1AAD19;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #1AAD19;
  border: 2rpx solid #1AAD19;
  border-radius: 50rpx;
  padding: 22rpx 40rpx;
  font-size: 30rpx;
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-danger::after {
  border: none;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.tag-green {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-orange {
  background: #fff3e0;
  color: #ef6c00;
}

.tag-red {
  background: #ffebee;
  color: #c62828;
}

.tag-blue {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-purple {
  background: #f3e5f5;
  color: #7b1fa2;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty text {
  font-size: 28rpx;
  display: block;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}
