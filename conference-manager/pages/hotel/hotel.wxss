/* 住宿页面样式 */
.my-hotel {
  background: linear-gradient(135deg, #1AAD19, #2ECC71);
  color: #fff;
}

.my-hotel .card-title {
  color: #fff;
  border-left-color: #fff;
}

.hotel-info {
  display: flex;
  padding: 20rpx 0;
}

.hotel-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.hotel-detail {
  flex: 1;
}

.hotel-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.hotel-address {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 12rpx;
}

.hotel-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.hotel-tags .tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
}

.room-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.room-type, .room-number {
  font-size: 26rpx;
}

.stay-info {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.hotel-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.hotel-actions button {
  flex: 1;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item image {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

.hotel-list {
  margin-top: 20rpx;
}

.hotel-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.hotel-item:last-child {
  border-bottom: none;
}

.hotel-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.hotel-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hotel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.hotel-content .hotel-name {
  font-size: 30rpx;
  color: #333;
}

.hotel-rating {
  display: flex;
  align-items: baseline;
}

.rating-score {
  font-size: 36rpx;
  color: #ff9800;
  font-weight: bold;
}

.rating-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.hotel-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.hotel-tags .tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
}

.hotel-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.hotel-location image {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.hotel-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ff4d4f;
}

.price-number {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

.room-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.room-status.available {
  background: #e8f5e9;
  color: #2e7d32;
}

.room-status.limited {
  background: #fff3e0;
  color: #ef6c00;
}

.room-status.full {
  background: #ffebee;
  color: #c62828;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #1AAD19;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.notice-list {
  padding: 10rpx 0;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1AAD19;
  margin-right: 16rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
