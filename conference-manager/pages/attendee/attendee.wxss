/* 参会人员样式 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 16rpx 30rpx;
  margin-bottom: 20rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
}

.search-bar image {
  width: 40rpx;
  height: 40rpx;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-card .stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1AAD19;
  display: block;
}

.stat-card .stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.attendee-list {
  padding: 10rpx 0;
}

.attendee-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.attendee-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.attendee-info {
  flex: 1;
}

.attendee-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.attendee-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.attendee-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.attendee-status.checked {
  background: #e8f5e9;
  color: #2e7d32;
}

.attendee-status.pending {
  background: #fff3e0;
  color: #ef6c00;
}

.attendee-company {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.attendee-title {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.attendee-tags {
  display: flex;
  gap: 12rpx;
}

.attendee-tags .tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
}
