/* 议程页面样式 */
.date-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.date-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #f0f0f0;
}

.date-tab.active {
  border-color: #1AAD19;
  background: #e8f5e9;
}

.date-day {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.date-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.agenda-list {
  padding: 10rpx 0;
}

.agenda-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #1AAD19;
}

.agenda-item.completed {
  border-left-color: #bdbdbd;
  opacity: 0.7;
}

.agenda-item.ongoing {
  border-left-color: #ff9800;
  background: #fff8e1;
}

.agenda-time {
  width: 120rpx;
  text-align: center;
  padding-right: 20rpx;
  border-right: 2rpx solid #f0f0f0;
}

.time-start {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.time-end {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.agenda-content {
  flex: 1;
  padding: 0 20rpx;
}

.agenda-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.agenda-speaker {
  font-size: 26rpx;
  color: #1AAD19;
  display: block;
  margin-bottom: 4rpx;
}

.agenda-location {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.agenda-tags {
  display: flex;
  gap: 12rpx;
}

.agenda-tags .tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
}

.agenda-action {
  display: flex;
  align-items: center;
}

.btn-mini {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid #1AAD19;
  color: #1AAD19;
  border-radius: 30rpx;
  background: transparent;
}

.btn-mini.active {
  background: #1AAD19;
  color: #fff;
}

.btn-mini::after {
  border: none;
}
