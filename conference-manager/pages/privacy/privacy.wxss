/* 隐私页面样式 */
.privacy-content {
  padding: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.privacy-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.privacy-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
}
