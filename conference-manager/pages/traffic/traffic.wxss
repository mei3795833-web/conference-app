/* 交通页面样式 */
.map-container {
  position: relative;
  margin: -20rpx -20rpx 20rpx;
}

.map-overlay {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-btn {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.location-btn image {
  width: 40rpx;
  height: 40rpx;
}

.navigate-btn {
  background: #1AAD19;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(26,173,25,0.3);
}

.transport-tabs {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.transport-tab {
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.transport-tab.active {
  background: #e8f5e9;
}

.transport-tab image {
  width: 56rpx;
  height: 56rpx;
  display: block;
  margin: 0 auto 8rpx;
}

.transport-tab text {
  font-size: 24rpx;
  color: #666;
}

.transport-tab.active text {
  color: #1AAD19;
  font-weight: 500;
}

.route-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.route-item:last-child {
  border-bottom: none;
}

.route-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.route-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.route-time {
  font-size: 26rpx;
  color: #1AAD19;
}

.route-detail {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.route-stations {
  font-size: 26rpx;
  color: #666;
}

.route-price {
  font-size: 28rpx;
  color: #ff9800;
  font-weight: 500;
}

.route-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
}

.taxi-info {
  text-align: center;
  padding: 40rpx;
}

.taxi-estimate {
  font-size: 48rpx;
  color: #ff9800;
  font-weight: bold;
  display: block;
}

.taxi-duration {
  font-size: 28rpx;
  color: #666;
  margin: 16rpx 0 40rpx;
  display: block;
}

.parking-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.parking-item:last-child {
  border-bottom: none;
}

.parking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.parking-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.parking-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.parking-status.available {
  background: #e8f5e9;
  color: #2e7d32;
}

.parking-status.limited {
  background: #fff3e0;
  color: #ef6c00;
}

.parking-status.full {
  background: #ffebee;
  color: #c62828;
}

.parking-detail {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.parking-distance {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.parking-distance image {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.shuttle-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.shuttle-item:last-child {
  border-bottom: none;
}

.shuttle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.shuttle-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.shuttle-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.shuttle-status.running {
  background: #e8f5e9;
  color: #2e7d32;
}

.shuttle-status.waiting {
  background: #fff3e0;
  color: #ef6c00;
}

.shuttle-stops {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.shuttle-stops text {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  color: #666;
}

.shuttle-schedule {
  font-size: 26rpx;
  color: #1AAD19;
}

.traffic-status {
  padding: 10rpx 0;
}

.status-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.status-indicator.green {
  background: #4caf50;
}

.status-indicator.yellow {
  background: #ff9800;
}

.status-indicator.red {
  background: #f44336;
}

.service-list {
  padding: 10rpx 0;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.service-item:last-child {
  border-bottom: none;
}

.service-item image {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.service-phone {
  font-size: 26rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.call-btn {
  font-size: 28rpx;
  color: #1AAD19;
  padding: 12rpx 24rpx;
  border: 2rpx solid #1AAD19;
  border-radius: 30rpx;
}
