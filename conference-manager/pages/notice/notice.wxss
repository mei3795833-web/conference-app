/* 通知页面样式 */
.notice-list {
  padding: 10rpx 0;
}

.notice-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.notice-item.read {
  opacity: 0.7;
}

.notice-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff4d4f;
  margin-right: 16rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.notice-time {
  font-size: 24rpx;
  color: #999;
}

.notice-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
}

.notice-tags .tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.notice-tags .tag.urgent {
  background: #ffebee;
  color: #c62828;
}

.notice-tags .tag.normal {
  background: #e3f2fd;
  color: #1565c0;
}

.notice-tags .tag.system {
  background: #f3e5f5;
  color: #7b1fa2;
}
